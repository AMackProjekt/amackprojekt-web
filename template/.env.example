# Site Configuration
NEXT_PUBLIC_SITE_URL=https://{{CLIENT_DOMAIN}}
NEXT_PUBLIC_SITE_NAME={{CLIENT_NAME}}
NEXT_PUBLIC_CONTACT_EMAIL={{CONTACT_EMAIL}}

# Analytics (Optional - Remove if not using)
NEXT_PUBLIC_GA_MEASUREMENT_ID={{GA_MEASUREMENT_ID}}
NEXT_PUBLIC_GTM_ID={{GTM_ID}}

# Feature Flags
NEXT_PUBLIC_ENABLE_CHATBOT={{ENABLE_CHATBOT}}
NEXT_PUBLIC_ENABLE_ANALYTICS={{ENABLE_ANALYTICS}}
NEXT_PUBLIC_ENABLE_NEWSLETTER={{ENABLE_NEWSLETTER}}

# Third-party Integrations (Optional)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=

# API Configuration (if using backend)
NEXT_PUBLIC_API_URL=
API_SECRET_KEY=

# Social Media (Optional)
NEXT_PUBLIC_TWITTER_URL={{TWITTER_URL}}
NEXT_PUBLIC_LINKEDIN_URL={{LINKEDIN_URL}}
NEXT_PUBLIC_FACEBOOK_URL={{FACEBOOK_URL}}
NEXT_PUBLIC_INSTAGRAM_URL={{INSTAGRAM_URL}}
